{
  "name": "Kamereo Dark",
  "dataColors": ["#5B9BD5", "#7FBFF0", "#A9A9A9", "#C8C8C8", "#8AB4F8", "#4F9FE0", "#B0B0B0", "#6E6E6E"],
  "foreground": "#FFFFFF",
  "foregroundNeutralSecondary": "#D0D0D0",
  "foregroundNeutralTertiary": "#9A9A9A",
  "background": "#1A1A1A",
  "backgroundLight": "#262626",
  "backgroundNeutral": "#2D2D30",
  "tableAccent": "#5B9BD5",
  "visualStyles": {
    "page": {
      "*": {
        "background": [{ "color": { "solid": { "color": "#1A1A1A" } }, "transparency": 0 }],
        "outspace": [{ "color": { "solid": { "color": "#1A1A1A" } }, "transparency": 0 }]
      }
    },
    "*": {
      "*": {
        "background": [{ "show": true, "color": { "solid": { "color": "#262626" } }, "transparency": 0 }],
        "border": [{ "show": true, "color": { "solid": { "color": "#3A3A3A" } }, "radius": 14 }],
        "title": [{ "show": true, "fontColor": { "solid": { "color": "#FFFFFF" } }, "fontSize": 13, "bold": true, "alignment": "left" }],
        "subTitle": [{ "show": true, "fontColor": { "solid": { "color": "#B0B0B0" } }, "fontSize": 10 }],
        "categoryAxis": [{ "labelColor": { "solid": { "color": "#E0E0E0" } }, "gridlineColor": { "solid": { "color": "#333333" } } }],
        "valueAxis": [{ "labelColor": { "solid": { "color": "#E0E0E0" } }, "gridlineColor": { "solid": { "color": "#333333" } } }],
        "labels": [{ "color": { "solid": { "color": "#FFFFFF" } } }],
        "legend": [{ "labelColor": { "solid": { "color": "#E0E0E0" } } }]
      }
    }
  }
}
